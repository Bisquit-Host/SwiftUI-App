    "Info.Backup" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A backup is a safeguard duplicate of vital data, enabling restoration in case of loss or damage, helping prevent significant data loss."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een back-up is een veiligheidsduplicaat van essentiële gegevens, waarmee herstel mogelijk is in geval van verlies of beschadiging, en helpt om aanzienlijk gegevensverlies te voorkomen."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Резервная копия - это надежный дубликат жизненно важных данных, позволяющий восстановить их в случае потери или повреждения, помогая предотвратить значительную потерю данных."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Резервная копия - это надежный дубликат жизненно важных данных, позволяющий восстановить их в случае потери или повреждения, помогая предотвратить значительную потерю данных."
          }
        }
      }
    },
    "Info.CloudStorage" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud ensures the secure and efficient storage of your precious data, including API-keys."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud zorgt voor de veilige en efficiënte opslag van uw waardevolle gegevens, inclusief API-sleutels."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud обеспечивает безопасное и эффективное хранение ваших данных, включая API-ключи."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "iCloud обеспечивает безопасное и эффективное хранение ваших ценных данных, включая API-ключи."
          }
        }
      }
    },
    "Info.Database" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Databases are essential for the operation of certain plugins and effective data management."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Databases zijn essentieel voor de werking van bepaalde plug-ins en effectief gegevensbeheer."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Базы данных необходимы для функционирования некоторых плагинов и эффективного управления данными."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Базы данных необходимы для функционирования некоторых плагинов и эффективного управления данными."
          }
        }
      }
    },
    "Info.Schedule" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schedules automate tasks such as sending commands, generating backups, or performing power actions. They enhance efficiency, reduce manual intervention, and help maintain consistent system operations."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schema's automatiseren taken zoals het sturen van commando's of het genereren van back-ups. Ze verhogen de efficiëntie, verminderen handmatige interventie en helpen bij het handhaven van consistente systeemoperaties."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Расписания автоматизируют такие задачи, как отправка команд, создание резервных копий или перезагрузка сервера. Они повышают эффективность, сокращают ручное вмешательство и помогают поддерживать согласованную работу системы."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Розклади автоматизують такі завдання, як надсилання команд, створення резервних копій або виконання дій з живленням. Вони підвищують ефективність, скорочують ручне втручання і допомагають підтримувати узгоджену роботу системи."
          }
        }
      }
    },

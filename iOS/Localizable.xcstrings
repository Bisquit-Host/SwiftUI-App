      }
    },
    "Intro.Text1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All plans feature the powerful AMD Ryzen 9 5950X processor running at 4.9GHz, as well as high-speed NVMe SSD drives for optimal performance"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle abonnementen zijn voorzien van de krachtige AMD Ryzen 9 5950X-processor die draait op 4,9 GHz, evenals snelle NVMe SSD voor optimale prestaties"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Все тарифы оснащены мощным процессором AMD Ryzen 9 5950X, работающим на частоте 4,9 ГГц, а также высокоскоростными NVMe SSD для оптимальной производительности"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Все тарифы оснащены мощным процессором AMD Ryzen 9 5950X, работающим на частоте 4,9 ГГц, а также высокоскоростными NVMe SSD для оптимальной производительности"
          }
        }
      }
    },
    "Intro.Text2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "With our exclusive app you have the convenient opportunity to manage your servers from anywhere at any time"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Met onze exclusieve app heb je de handige mogelijkheid om je servers overal en altijd te beheren"

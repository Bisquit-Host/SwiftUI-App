    "Intro.Text0" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your favorite hosting is now always in your pocket!"
          }
        },
        "nl" : {
          "stringUnit" : {

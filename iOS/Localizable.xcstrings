    "Biometry Usage" : {
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Использование Биометрии"
          }
        }
      }
    },
    "Biometry usage description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enabling biometric access does not share your biometric data with Bisquit.Host. Bisquit.Host app uses the Keychain on your device to securely store authentication tokens that can only be accessed with your biometrics. You can disable biometric authentication (Face/Touch ID) at any time through the settings in the Bisquit.Host app."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Включение биометрической аутентификации не предоставляет вашу биометрическую информацию Bisquit.Host. Приложение Bisquit.Host использует Keychain на вашем устройстве для безопасного хранения токенов аутентификации, которые могут быть доступны только с использованием вашей биометрии. Вы можете отключить биометрическую аутентификацию (Face/Touch ID) в любое время через настройки в приложении Bisquit.Host."
          }
        }
      }
    },
